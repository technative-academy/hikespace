{
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "https://hikespace-production.up.railway.app/api/auth/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://hikespace-production.up.railway.app/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}